# =====================================================
# Bandwidth Bridge - Environment Variables
# Copy this file to .env and fill in your values
# =====================================================

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bandwidth_bridge
DB_USER=bbuser
DB_PASSWORD=bbpassword123

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_use_256_bits
JWT_EXPIRY=24h

# STUN/TURN Server Configuration
# Free STUN servers (Google's public STUN servers)
STUN_SERVER_1=stun:stun.l.google.com:19302
STUN_SERVER_2=stun:stun1.l.google.com:19302
STUN_SERVER_3=stun:stun.stunprotocol.org:3478

# TURN server (optional - needed for strict NAT traversal)
# TURN_SERVER=turn:your-turn-server.com:3478
# TURN_USERNAME=your_turn_username
# TURN_PASSWORD=your_turn_password

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Analytics
MAX_BANDWIDTH_MBPS=1000
DEFAULT_CREDIT_BALANCE=100
